{
  "name": "central-de-anime-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "test:backend": "npm --workspace backend test",
    "test:frontend": "npm --workspace frontend test",
    "test": "npm run test:backend && npm run test:frontend",
    "coverage:backend": "npm --workspace backend run test:coverage",
    "coverage:frontend": "npm --workspace frontend run test:coverage",
    "coverage": "npm run coverage:backend && npm run coverage:frontend",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "build": "npm run build:backend && npm run build:frontend",
    "seed:backend": "npm --workspace backend run seed:dev"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
